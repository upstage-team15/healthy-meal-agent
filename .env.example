# Upstage API key: https://console.upstage.ai/
UPSTAGE_API_KEY=your_upstage_api_key
LLM_MODEL=solar-pro3

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# ── 배포(docker compose)용 ──
# 실행 환경 표시 (production / development)
ENVIRONMENT=development

# docker compose가 pull할 이미지. 로컬 빌드는 비워두면 됨(기본값 사용).
# 배포(CD)에서는 GHCR 이미지 태그가 자동 주입됨. 예: ghcr.io/owner/repo:sha-abc1234
# IMAGE=healthy-meal-agent:latest

# UI(streamlit)가 호출할 API 주소.
# - 로컬(비-docker): http://127.0.0.1:8000 (기본값)
# - docker compose: http://api:8000 (compose가 자동 주입)
# HEALTHY_MEAL_API_URL=http://127.0.0.1:8000
