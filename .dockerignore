# Docker 빌드 시 이미지에 넣지 않을 것 (빌드 속도 ↑, 보안)

# 가상환경 (빌드 스테이지에서 새로 만듦)
.venv/
venv/
ENV/

# 비밀값 — 절대 이미지에 넣으면 안 됨 (강의 30p)
.env
.env.*
!.env.example
.streamlit/secrets.toml

# 파이썬 캐시
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Git
.git/
.gitignore
.gitattributes

# IDE·에디터
.idea/
.vscode/
.DS_Store

# 문서·에이전트 (런타임 불필요)
docs/
.claude/
.agents/

# CI (이미지 안에 필요 없음)
.github/

# 로컬 원본 데이터 (런타임은 foods_samsam.csv만 씀 → app/data로 이미 COPY됨)
# 원본 cookrcp01_all.csv는 크고 런타임에 불필요하지만 app/data에 있어 COPY됨.
